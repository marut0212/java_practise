import java.util.Scanner;

public class Myjava{
  public static void main(String[] args){
    
   int A[][]={{2,4,6},{4,5,6},{3,5,7}};
   int B[][]={{1,3,5},{6,7,8},{9,6,2}};

   int C[][]=new int[3][3];

   for(int i=0;i<A.length;i++){
      for(int j=0;j<A[0].length;j++){
         for(int k=0;k<B[0].length;k++){
         C[i][j]+=A[i][k]*B[k][j];
      }
   }
}
   for(int x[]: C){
      for(int y:x){
         System.out.print(y+" ");
      }
      System.out.println("");
   }
    }  
  }
