import java.util.Scanner;

public class Myjava {
    public static void main(String[] args) {
      Scanner sc = new Scanner(System.in);
      System.out.print("enter number: ");
      int n = sc.nextInt();
      int m=n;
      int sum=0;
      int r;
      while(n>0){
        r=n%10;
        n=n/10;
        sum = sum+r*r*r;
      }
      if(sum==m){
        System.out.println("Armstrong");
      }
      else{
        System.out.print("Not armstrong");
      }
      sc.close();
  }
}
