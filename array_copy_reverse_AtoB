import java.util.Scanner;

public class Myjava{
  public static void main(String[] args){
     
    int A[]={4,2,1,8,9,6,5,3,7};
     int B[]=new int[9];
     
        
        for(int x:A)
           System.out.print(x+",");
           System.out.println("");
         
    
        for(int i=0;i<=A.length-1;i++)
        {
           B[i]=A[(A.length-1)-i];
        }
       

        for(int x:B)
           System.out.print(x+",");
           System.out.println("");
        
    }  
  }
