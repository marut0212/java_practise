import java.util.Scanner;

public class Myjava{
   static int gcd(int x,int y){
      while(y!=0){
         int temp=y;
         y=x%y;
         x=temp;
      }
      return x;
   }
   public static void main(String[] args){
      int a,b,c;
      Scanner sc=new Scanner(System.in);
      System.out.print("Enter the numbers: ");
      a=sc.nextInt();
      b=sc.nextInt();
      c=gcd(a,b);
      System.out.println("GCD = "+c);
  }
  }
