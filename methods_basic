import java.util.Scanner;

public class Myjava{

   static int max(int x, int y){
      x++;
      if(x>y){
         return x;
      }
      else{
         return y;
      }
   }
  public static void main(String[] args){
    int a,b,c;
    Scanner sc=new Scanner(System.in);
    System.out.print("enter the numbers");
    a=sc.nextInt();
    b=sc.nextInt();
    c=max(a,b);
    System.out.println(c+" is greater");
    }  
  }
