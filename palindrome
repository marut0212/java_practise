import java.util.Scanner;

public class Myjava {
    public static void main(String[] args) {
      Scanner sc = new Scanner(System.in);
      System.out.print("enter number: ");
      int n = sc.nextInt();
      int m=n;
      int rev=0;
      int r;
      while(n>0){
        r=n%10;
        rev=rev*10+r;
        n=n/10;
      }
       if(rev==m){
        System.out.println("Palindrome");
       }
       else{
        System.out.println("not a palindrome");
       }
      sc.close();
  }
}
